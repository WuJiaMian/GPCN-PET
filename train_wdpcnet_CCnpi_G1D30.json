{
  "task": "wdpcnet_CCnpi_G1D30"
  , "model": "wdpcnet_npi"
  , "mask": "G1D30"
  , "gpu_ids": [0]
  , "dist": false
  , "n_channels": 1
  , "manual_seed": 42
  , "path": {
    "root": "mri_recon"
    , "pretrained_netG": null      // path of pretrained model
    , "pretrained_netE": null      // path of pretrained model
  }

  , "datasets": {
    "train": {
      "name": "train_dataset"
      , "dataset_type": "ccsagnpi"
      , "dataroot_H": "trainsets/H"     // path of H training dataset
      , "dataroot_L": "trainsets/L"     // path of H training dataset
      , "mask": "G1D30"   // find keywords in ./models/select_mask.py
      , "H_size": 128   // patch number
      , "sigma": 15
      , "sigma_test": 15
      , "is_noise": false    // add noise in k-space
      , "noise_level": 0.0    // NL = S/(S+N)
      , "noise_var": 0.1
      , "is_mini_dataset": true   // for debug
      , "mini_dataset_prec": 1
      , "dataloader_shuffle": true
      , "dataloader_num_workers": 1
        , "dataloader_batch_size": 1
    }
    , "test": {
      "name": "test_dataset"
      , "dataset_type": "ccsagnpi"
      , "dataroot_H": "testsets/H"     // path of H training dataset
      , "dataroot_L": "testsets/L"     // path of H training dataset
      , "mask": "G1D30"   // find keywords in ./models/select_mask.py
      , "sigma": 15
      , "sigma_test": 15
      , "is_noise": false    // add noise in k-space
      , "noise_level": 0.0    // NL = S/(S+N)
      , "noise_var": 0.1
      , "resize_for_fid": false
    }
  }

  , "netG": {
    "net_type": "swinir" 
    , "upscale": 1 
    , "in_chans": 1 
    , "img_size": 128
    , "window_size": 4
    , "img_range": 1.0
    , "depths": [6,6,6]
    , "embed_dim": 18    //54 72 90
    , "num_heads": [6,6,6]
    , "mlp_ratio": 2 
    , "upsampler": null
    , "resi_connection": "1conv"    // '1conv', '3conv'
    , "init_type": "default"
  }

  , "train": {
    "G_lossfn_type": "charbonnier"
    , "G_lossfn_weight": 1.0
    , "G_charbonnier_eps": 1e-9
    , "alpha": 15
    , "beta": 0.0010
    , "gamma": 0.0025
    , "E_decay": 0.999
    , "G_optimizer_type": "adam"    // fixed, adam is enough
    , "G_optimizer_lr": 2e-4    // learning rate default 2e-4
    , "G_optimizer_wd": 0    // weight decay, default 0
    , "G_optimizer_clipgrad": null
    , "G_optimizer_reuse": true

    , "G_scheduler_type": "MultiStepLR"
    , "G_scheduler_milestones": [1000000]
    , "G_scheduler_gamma": 0.5

    , "G_regularizer_orthstep": null
    , "G_regularizer_clipstep": null

    , "G_param_strict": true
    , "E_param_strict": true

    , "checkpoint_test": 1 // for testing 10000
    , "checkpoint_save": 10000  // for saving model 10000
    , "checkpoint_print": 200   // for print 200
    , "is_early_stopping": false
    , "early_stopping_num": 8
    , "freeze_patch_embedding": false
  }
}
